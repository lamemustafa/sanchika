{
  "name": "@sanchika/primitives",
  "version": "0.0.0",
  "private": true,
  "description": "Sanchika primitive class and accessibility contracts for compliance-grade interfaces.",
  "license": "Apache-2.0",
  "keywords": [
    "sanchika",
    "design-system",
    "compliance",
    "primitives"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lamemustafa/sanchika.git",
    "directory": "packages/primitives"
  },
  "bugs": {
    "url": "https://github.com/lamemustafa/sanchika/issues"
  },
  "homepage": "https://github.com/lamemustafa/sanchika/tree/master/packages/primitives#readme",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs styles.css",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@sanchika/tokens": "workspace:*"
  }
}
