{
  "name": "@sanchika/gallery",
  "version": "0.0.0",
  "private": true,
  "description": "Sanchika static gallery proof surface for primitive and pattern contract review.",
  "license": "Apache-2.0",
  "keywords": [
    "sanchika",
    "design-system",
    "compliance",
    "gallery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lamemustafa/sanchika.git",
    "directory": "packages/gallery"
  },
  "bugs": {
    "url": "https://github.com/lamemustafa/sanchika/issues"
  },
  "homepage": "https://github.com/lamemustafa/sanchika/tree/master/packages/gallery#readme",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sanchika/patterns": "workspace:*",
    "@sanchika/primitives": "workspace:*",
    "@sanchika/tokens": "workspace:*"
  }
}
