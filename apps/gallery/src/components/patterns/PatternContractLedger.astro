---
import type { ProductPatternContract } from "@sanchika/patterns";
import { primitiveClassName, textClassName } from "@sanchika/primitives";

interface Props {
  contracts: readonly ProductPatternContract[];
}

const { contracts } = Astro.props;

function proofStates(contract: ProductPatternContract) {
  const first = contract.states[0];
  const last = contract.states.at(-1);
  return first && last && first.name !== last.name ? [first, last] : first ? [first] : [];
}

function stateClass(contract: ProductPatternContract, stateName: string) {
  return `${contract.css.stateClassPrefix}${stateName}`;
}
---

<section class="pattern-reference-ledger" aria-labelledby="pattern-contract-ledger-title">
  <div class="pattern-reference-ledger__intro">
    <span class={textClassName("eyebrow")}>Package contract ledger</span>
    <h2 id="pattern-contract-ledger-title">The visible example and the adopter contract travel together.</h2>
    <p>Each entry is emitted from <code>@sanchika/patterns</code>; the gallery does not maintain a second inventory.</p>
  </div>
  <div>
    {contracts.map((contract) => (
      <article class="pattern-reference-contract" data-pattern-contract={contract.name}>
        <div class="pattern-reference-contract__title">
          <h3>{contract.name}</h3>
          <span class={primitiveClassName("Badge", contract.evidenceStatus === "consumer-verified" ? "success" : "info", "sm")}>
            {contract.maturity} · {contract.evidenceStatus}
          </span>
        </div>
        <p>{contract.purpose}</p>
        <div class="pattern-reference-contract__meta">
          <section>
            <h4>Anatomy</h4>
            <ul>{contract.anatomy.map((part) => <li><strong>{part.name}</strong> — {part.purpose}</li>)}</ul>
          </section>
          <section>
            <h4>Variants and states</h4>
            <ul>
              {contract.variants.map((variant) => <li>Variant: {variant.name}</li>)}
              {contract.states.map((state) => <li>State: {state.name} — {state.requiredVisibleSignals.join(", ")}</li>)}
            </ul>
          </section>
          <section>
            <h4>Rendered state proofs</h4>
            <div class="pattern-reference-state-proofs">
              {proofStates(contract).map((state) => (
                <article
                  class={`pattern-reference-state-proof ${stateClass(contract, state.name)}`}
                  data-product-pattern-state={`${contract.name}:${state.name}`}
                  aria-label={`${contract.name} ${state.name} state proof`}
                >
                  <strong>{state.name}</strong>
                  <p>{state.purpose}</p>
                  <ul>{state.requiredVisibleSignals.map((signal) => <li>{signal}</li>)}</ul>
                  <small>{contract.copyObligations[0]}</small>
                </article>
              ))}
            </div>
          </section>
          <section>
            <h4>Adoption boundary</h4>
            <ul>
              {contract.trustBoundaries.map((boundary) => <li>{boundary}</li>)}
              {contract.consumerResponsibilities.map((responsibility) => <li>Consumer: {responsibility}</li>)}
              <li>CSS: <code>{contract.css.baseClass}</code></li>
              <li>Route: <a href={contract.exemplarRoutes[0]}>{contract.exemplarRoutes[0]}</a></li>
            </ul>
          </section>
        </div>
      </article>
    ))}
  </div>
</section>
