---
import { primitiveClassName, primitiveGroups, textClassName } from "@sanchika/primitives";

const inlineStatus = primitiveGroups.searchStateFeedback.find((contract) => contract.name === "InlineStatus");
if (!inlineStatus || inlineStatus.name !== "InlineStatus") throw new Error("S5 group must include InlineStatus");
const tones = inlineStatus.variants.find((variant) => variant.name === "tone")?.values ?? [];
---

<section class={primitiveClassName("Section", { space: "lg", boundary: "bordered" })} aria-labelledby="s5-state-title">
  <div class={primitiveClassName("Stack", { gap: "lg" })}>
    <div><p class={textClassName("eyebrow")}>State and feedback</p><h2 id="s5-state-title" class={textClassName("heading")}>State is named before color supports it.</h2></div>
    <div class={primitiveClassName("Cluster", { gap: "sm" })}>
      {tones.map((tone) => <span class={primitiveClassName("InlineStatus", { tone })}><span class="sk-inline-status__marker" aria-hidden="true">{tone === "success" ? "✓" : tone === "warning" ? "!" : tone === "danger" ? "×" : "i"}</span><span>{tone} state</span>{tone === "info" ? <span class="sk-inline-status__meta">Source 14-07-2026</span> : null}</span>)}
    </div>

    <div class="s5-state-grid">
      <section class={primitiveClassName("Surface", { variant: "inset", padding: "md" })} aria-busy="true" aria-labelledby="s5-loading-title">
        <h3 id="s5-loading-title">Loading synthetic review rows</h3><p class={textClassName("caption")}>The owning region carries aria-busy; shapes are assistive-hidden.</p>
        <div class="s5-skeleton-stack" aria-hidden="true"><span class={primitiveClassName("Skeleton", { form: "text" })}></span><span class={primitiveClassName("Skeleton", { form: "row" })}></span><span class={primitiveClassName("Skeleton", { form: "block" })}></span></div>
      </section>
      <section class={primitiveClassName("EmptyState", { kind: "empty" })} data-empty-kind="empty"><h3>No source records yet</h3><p>Add a synthetic source record before preparing a review.</p><div class="sk-empty-state__actions"><button class={primitiveClassName("Button", "brand", "md")} type="button">Add source record</button></div><p class="sk-empty-state__detail">Example only; no record is created.</p></section>
      <section class={primitiveClassName("EmptyState", { kind: "unavailable" })} data-empty-kind="unavailable"><h3>Source records unavailable</h3><p>This synthetic account cannot read the source. Ask an authorised workspace owner for access.</p><div class="sk-empty-state__actions"><a class={primitiveClassName("Link")} href="#s5-contract-ledger">Review access guidance</a></div><p class="sk-empty-state__detail">Permission and source gaps remain distinct from an empty collection.</p></section>
      <section class={primitiveClassName("ErrorState", { severity: "recoverable" })}><h3>Could not load the synthetic source</h3><p>Retry the local fixture or inspect the reference before continuing.</p><div class="sk-error-state__actions"><button class={primitiveClassName("Button", "danger", "md")} type="button">Retry local fixture</button><a class={primitiveClassName("Link")} href="#s5-contract-ledger">Open support guidance</a></div><p class="sk-error-state__reference">Reference S5-EXAMPLE-001</p><details class="sk-error-state__details"><summary>Technical detail</summary><p>Synthetic network failure. No stack trace or private data is shown.</p></details></section>
      <section class={primitiveClassName("ErrorState", { severity: "blocking" })} data-error-severity="blocking"><h3>Review cannot continue</h3><p>The synthetic source reference is missing. Attach a reviewed fixture before continuing.</p><div class="sk-error-state__actions"><a class={primitiveClassName("Link")} href="#s5-contract-ledger">Inspect required source guidance</a></div><p class="sk-error-state__reference">Reference S5-BLOCKED-001</p></section>
    </div>
  </div>
</section>
