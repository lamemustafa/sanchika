---
import {
  primitiveClassName,
  primitiveGroups,
  textClassName,
  type PrimitiveClassOptionsFor,
  type PrimitiveContract,
  type TextRole,
} from "@sanchika/primitives";

type SurfaceVariant = NonNullable<PrimitiveClassOptionsFor<"Surface">["variant"]>;

const s4Specs: readonly PrimitiveContract[] = primitiveGroups.foundation;
const surfaceSpec = s4Specs.find((primitive) => primitive.name === "Surface");
const textSpec = s4Specs.find((primitive) => primitive.name === "Text");
if (!surfaceSpec || !textSpec) throw new Error("Foundation primitive group must include Surface and Text contracts");
const surfaceVariants = surfaceSpec.variants.find((variant) => variant.name === "variant")?.values as readonly SurfaceVariant[] | undefined;
const textRoles = textSpec.variants.find((variant) => variant.name === "role")?.values as readonly TextRole[] | undefined;
if (!surfaceVariants || !textRoles) throw new Error("Surface variants and Text roles must come from authoritative contracts");
---

<main id="gallery-content" class={primitiveClassName("Container", { width: "wide" })} data-sanchika-gallery="foundation-primitives" data-sanchika-example="synthetic">
  <header class="sk-foundation-masthead">
    <a class={primitiveClassName("Link", { variant: "quiet" })} href="/">← Sanchika gallery</a>
    <span class={textClassName("eyebrow")}>S4 / foundation primitives</span>
  </header>

  <section class={`${primitiveClassName("Section", { space: "lg" })} sk-foundation-hero`} aria-labelledby="foundation-title">
    <div class={primitiveClassName("Stack", { gap: "md", align: "start" })}>
      <p class={textClassName("eyebrow")}>Typed contracts · generated tokens · zero runtime</p>
      <h1 id="foundation-title" class={textClassName("display")}>Layout is a contract, not a screenshot.</h1>
      <p class={textClassName("lead")}>Sanchika’s S4 layer makes structure, measure, rhythm, visual planes, text roles, and navigation semantics reusable without absorbing product workflow geometry.</p>
      <div class={primitiveClassName("Cluster", { gap: "sm", align: "center" })}>
        <a class={primitiveClassName("Link", { variant: "default" })} href="#layout-proof">Inspect layout proof</a>
        <a class={primitiveClassName("Link", { variant: "quiet" })} href="#contract-ledger">Read contract ledger</a>
      </div>
    </div>
  </section>

  <hr class={primitiveClassName("Divider")} />

  <section id="layout-proof" class={primitiveClassName("Section", { space: "lg" })} aria-labelledby="layout-title">
    <div class={primitiveClassName("Stack", { gap: "lg" })}>
      <div class={primitiveClassName("Stack", { gap: "sm", align: "start" })}>
        <p class={textClassName("eyebrow")}>Structure</p>
        <h2 id="layout-title" class={textClassName("heading")}>Bounded measure, explicit rhythm, resilient composition.</h2>
        <p class={textClassName("body")}>Every example keeps semantic HTML consumer-owned. The classes establish layout only.</p>
      </div>

      <div data-sk-primitive="Container" data-sk-state="default" class="sk-foundation-measure-demo">
        <span>Container / content measure</span>
        <div aria-hidden="true"></div>
      </div>

      <section data-sk-primitive="Section" data-sk-state="default" class={primitiveClassName("Section", { space: "sm", boundary: "bordered" })} aria-labelledby="section-example-title">
        <h3 id="section-example-title" class={textClassName("body")}>Section keeps rhythm separate from its semantic element.</h3>
      </section>

      <div data-sk-primitive="Stack" data-sk-state="default" class={`${primitiveClassName("Stack", { gap: "sm" })} sk-foundation-outline`}>
        <span>Stack item one</span><span>Stack item two with longer review copy that wraps in reading order.</span><span>Stack item three</span>
      </div>

      <div data-sk-primitive="Cluster" data-sk-state="default" class={`${primitiveClassName("Cluster", { gap: "sm", align: "center" })} sk-foundation-outline`}>
        <span class={primitiveClassName("Surface", { variant: "muted", padding: "sm" })}>Source attached</span>
        <span class={primitiveClassName("Surface", { variant: "muted", padding: "sm" })}>CA review required</span>
        <span class={primitiveClassName("Surface", { variant: "muted", padding: "sm" })}>Synthetic evidence</span>
      </div>

      <div data-sk-primitive="Grid" data-sk-state="default" class={primitiveClassName("Grid", { columns: "3", gap: "md" })}>
        {["Source", "Uncertainty", "Review state"].map((label) => <article class={primitiveClassName("Surface", { variant: "raised", padding: "md" })}><strong>{label}</strong><p class={textClassName("caption")}>A peer proof object with independent content.</p></article>)}
      </div>

      <div data-sk-primitive="Split" data-sk-state="default" class={primitiveClassName("Split", { ratio: "primary", gap: "lg" })}>
        <article class={`${primitiveClassName("Surface", { variant: "raised", padding: "lg" })} sk-split-primary`}><p class={textClassName("eyebrow")}>Primary</p><h3 class={textClassName("heading")}>Review the filing evidence.</h3><p class={textClassName("body")}>The dominant task remains first in source and reading order.</p></article>
        <aside class={`${primitiveClassName("Surface", { variant: "inset", padding: "md" })} sk-split-supporting`}><p class={textClassName("eyebrow")}>Supporting</p><p class={textClassName("body")}>Source: synthetic GST return packet<br />Confidence: requires professional review</p></aside>
      </div>
      <div data-sk-primitive="Split" data-sk-state="stacked" class="sk-foundation-stacked-proof"><strong>Stacked state</strong><span>At narrow widths, primary remains before supporting context.</span></div>
    </div>
  </section>

  <hr data-sk-primitive="Divider" data-sk-state="default" class={primitiveClassName("Divider")} />
  <div data-sk-primitive="Divider" data-sk-state="forced-colors" class="sk-foundation-state-note">Divider retains a system-color boundary in forced colors.</div>

  <section class={primitiveClassName("Section", { space: "lg" })} aria-labelledby="surface-title">
    <div class={primitiveClassName("Stack", { gap: "md" })}>
      <div><p class={textClassName("eyebrow")}>Planes</p><h2 id="surface-title" class={textClassName("heading")}>Surface owns the plane. Card owns grouped content.</h2></div>
      <div class={primitiveClassName("Grid", { columns: "3", gap: "md" })}>
        {surfaceVariants.map((variant) => <article data-sk-primitive="Surface" data-sk-state={variant === "default" ? "default" : undefined} data-sk-surface-variant={variant} class={primitiveClassName("Surface", { variant, padding: "md" })}><strong>{variant}</strong><p class={textClassName("caption")}>Token-driven surface variant.</p></article>)}
      </div>
      <div data-sk-primitive="Surface" data-sk-state="forced-colors" class="sk-foundation-state-note">Authored plane colors yield to Canvas and CanvasText while the boundary remains visible.</div>
      <div class={primitiveClassName("Split", { ratio: "balanced", gap: "md" })}>
        <article data-sk-primitive="Card" data-sk-state="default" class={primitiveClassName("Card", "neutral", "md")}><h3>Compatible Card</h3><p>Existing v0.0.2 classes now share Surface variables.</p></article>
        <a data-sk-primitive="Card" data-sk-state="focus-visible" class={primitiveClassName("Card", "warning", "md")} href="#card-guidance"><h3 id="card-guidance">Focusable only when interactive</h3><p>Static Card stays outside the tab order.</p></a>
      </div>
    </div>
  </section>

  <hr class={primitiveClassName("Divider")} />

  <section class={primitiveClassName("Section", { space: "lg" })} aria-labelledby="type-title">
    <div class={primitiveClassName("Stack", { gap: "md" })}>
      <div><p class={textClassName("eyebrow")}>Typography</p><h2 id="type-title" class={textClassName("heading")}>Roles carry hierarchy without dictating semantics.</h2></div>
      <div class="sk-foundation-type-ledger">
        {textRoles.map((role) => <div data-sk-text-role={role}><span class={textClassName("mono")}>{role}</span><p data-sk-primitive="Text" data-sk-state={role === "body" ? "default" : undefined} class={textClassName(role)}>{role === "data" ? "GSTIN 27ABCDE1234F1Z5 · ₹12,48,900.00 · 13 Jul 2026" : role === "mono" ? "sha256:9dc3…a27e" : role === "display" ? "Evidence before confidence." : role === "heading" ? "Professional review remains explicit." : role === "eyebrow" ? "Source / synthetic return" : role === "caption" ? "Caption: example evidence only." : role === "lead" ? "A lead introduces the decision without outranking the page title." : "Body copy carries the durable explanation in a readable measure."}</p></div>)}
      </div>
      <p data-sk-primitive="Text" data-sk-state="long-content" class={`${textClassName("body")} sk-foundation-long-copy`}>Long-content proof: M/s Shree Venkateshwara Industrial Components and Professional Services Private Limited — provisional reconciliation reference GST-FY-2025-26-Q4-EXAMPLE-000184 with review notes that must wrap without clipping, horizontal scrolling, or loss of semantic reading order.</p>
    </div>
  </section>

  <hr class={primitiveClassName("Divider")} />

  <section class={primitiveClassName("Section", { space: "lg" })} aria-labelledby="action-title">
    <div class={primitiveClassName("Stack", { gap: "lg" })}>
      <div><p class={textClassName("eyebrow")}>Actions and destinations</p><h2 id="action-title" class={textClassName("heading")}>Link is navigation. Button is action.</h2><p class={textClassName("body")}>Native semantics lead; classes never convert one behavior into the other.</p></div>
      <div class={primitiveClassName("Cluster", { gap: "md", align: "center" })}>
        <a data-sk-primitive="Link" data-sk-state="default" class={primitiveClassName("Link")} href="#contract-ledger">Inspect contract ledger</a>
        <a data-sk-primitive="Link" data-sk-state="hover" class={primitiveClassName("Link", { variant: "quiet" })} href="#link-guidance">Quiet destination</a>
        <a data-sk-primitive="Link" data-sk-state="focus-visible" class={`${primitiveClassName("Link")} sk-foundation-force-focus`} href="#link-guidance">Keyboard focus proof</a>
        <a data-sk-primitive="Link" data-sk-state="visited" class={primitiveClassName("Link")} href="#visited-link-proof">Visited contract</a>
        <button data-sk-primitive="Button" data-sk-state="default" class={primitiveClassName("Button", "brand", "md")} type="button">Run local check</button>
      </div>
      <p id="link-guidance" class={textClassName("caption")}>Destinations use Link. Commands use Button. Neither class supplies runtime behavior.</p>
      <div class={primitiveClassName("Grid", { columns: "3", gap: "md" })}>
        <a data-sk-primitive="LinkCard" data-sk-state="default" class={primitiveClassName("LinkCard", { variant: "default" })} href="#contract-ledger"><strong>Primitive contract ledger</strong><span class={textClassName("caption")}>One root anchor, supporting metadata, one tab stop.</span></a>
        <a data-sk-primitive="LinkCard" data-sk-state="hover" class={primitiveClassName("LinkCard", { variant: "muted" })} href="#surface-title"><strong>Surface guidance</strong><span class={textClassName("caption")}>A destination with no nested control.</span></a>
        <a data-sk-primitive="LinkCard" data-sk-state="focus-visible" class={`${primitiveClassName("LinkCard")} sk-foundation-force-focus`} href="#type-title"><strong>Typography roles</strong><span class={textClassName("caption")}>Focus spans the whole target boundary.</span></a>
      </div>
      <aside class={`${primitiveClassName("Surface", { variant: "inset", padding: "md" })} sk-foundation-prohibition`}><strong>Never nest interactive controls inside LinkCard.</strong><p class={textClassName("body")}>If a group needs a button, checkbox, menu, field, or second link, use a Surface or Card and place each control as a sibling target.</p></aside>
    </div>
  </section>

  <span data-sk-primitive="VisuallyHidden" data-sk-state="default" class={primitiveClassName("VisuallyHidden")}>Foundation proof contains synthetic examples and no live compliance data.</span>

  <section id="contract-ledger" class={primitiveClassName("Section", { space: "lg", boundary: "bordered" })} aria-labelledby="ledger-title">
    <div class={primitiveClassName("Stack", { gap: "md" })}>
      <div><p class={textClassName("eyebrow")}>Authoritative API</p><h2 id="ledger-title" class={textClassName("heading")}>Contract ledger</h2><p class={textClassName("body")}><code>PrimitiveClassOptions</code>, <code>PrimitiveClassOptionsFor</code>, <code>LegacyPrimitiveName</code>, and <code>textClassName</code> are exported. Legacy calls such as <code>primitiveClassName(&quot;Button&quot;, &quot;brand&quot;, &quot;md&quot;)</code> remain unchanged.</p></div>
      {s4Specs.map((primitive) => <details data-sk-contract={primitive.name} class={primitiveClassName("Surface", { variant: "default", padding: "md" })}><summary><strong>{primitive.name}</strong> — {primitive.role}</summary><div class={`${primitiveClassName("Stack", { gap: "sm" })} sk-foundation-contract-body`}><p>{primitive.purpose}</p><h3>Required states</h3><ul>{primitive.requiredStates.map((state) => <li>{state}</li>)}</ul><h3>State evidence</h3><ul>{primitive.stateEvidence.map((evidence) => <li><strong>{evidence.state}</strong>: {evidence.notes}<br /><span>Attributes: {evidence.attributes.join(", ") || "none"}</span><br /><span>Selectors: {evidence.selectors.join(", ")}</span></li>)}</ul>{primitive.standards?.length ? <><h3>Standards</h3><ul>{primitive.standards.map((standard) => <li><strong>{standard.id}</strong>: <a class={primitiveClassName("Link")} href={standard.sourceUrl}>{standard.sourceUrl}</a><ul>{standard.requirements.map((requirement) => <li>{requirement}</li>)}</ul></li>)}</ul></> : null}</div></details>)}
    </div>
  </section>

  <footer class={primitiveClassName("Section", { space: "md", boundary: "bordered" })}><p class={textClassName("caption")}>Static Sanchika evidence. Synthetic identifiers only. Consumers own semantics, runtime state, and product-specific workflow geometry.</p></footer>
</main>
