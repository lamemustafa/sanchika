---
import { primitiveClassName } from "@sanchika/primitives";
import { productPatternClassName } from "@sanchika/patterns";
import {
  craftFixture,
  craftTerritoryLabels,
  type CraftTerritory,
} from "../../content/craft-lab";

interface Props {
  territory: CraftTerritory;
}

const { territory } = Astro.props;
const label = craftTerritoryLabels[territory];
---

<main class={`craft-lab craft-lab--${territory}`} data-craft-proof data-stage="source">
  <header class="craft-lab__header">
    <a class="craft-wordmark" href={`/lab/${territory}/`} aria-label={`Sanchika ${label} direction`}>
      <span>Sanchika</span>
      <small lang="hi">संचिका</small>
    </a>
    <p>{label} · code-native direction · raster disabled</p>
  </header>

  <section class="craft-hero" aria-labelledby="craft-title">
    <div class="craft-hero__copy">
      <h1 id="craft-title">Make regulated interfaces that show their work.</h1>
      <p>Sanchika gives coding agents and engineers a repeatable way to turn source, uncertainty, and human review into clear, accessible product UI.</p>
      <div class={primitiveClassName("Cluster", { gap: "sm" })}>
        <a class="craft-action craft-action--primary" href="#decision-proof">Watch the decision</a>
        <a class="craft-action" href="/patterns/">Read the contracts</a>
      </div>
    </div>
    <aside class="craft-boundary" aria-label="Sanchika boundary">
      <span>Contract boundary</span>
      <strong>It supplies contracts and a review loop—not compliance judgment, customer evidence, or an application runtime.</strong>
    </aside>
  </section>

  <section id="decision-proof" class="craft-proof" aria-labelledby="proof-title">
    <div class="craft-proof__heading">
      <div>
        <span>Synthetic proof · {craftFixture.id}</span>
        <h2 id="proof-title">One decision. Three accountable parts.</h2>
      </div>
      <div class="craft-proof__controls">
        <button type="button" data-proof-advance>Advance proof</button>
        <span role="status" aria-live="polite" aria-atomic="true" data-proof-status>Source is in focus.</span>
      </div>
    </div>

    <div class="craft-proof__stage">
      <article class="craft-plane craft-plane--source" data-proof-step="source" aria-labelledby="source-title">
        <span>Source</span>
        <h3 id="source-title">{craftFixture.source}</h3>
        <dl>
          <div><dt>Recorded</dt><dd>{craftFixture.sourceDate}</dd></div>
          <div><dt>State</dt><dd>Linked · synthetic fixture</dd></div>
          <div><dt>Claim</dt><dd>No conclusion; source only</dd></div>
        </dl>
        <a href="#interpretation-title">Open source context</a>
      </article>

      <div class="craft-joint craft-joint--first" aria-hidden="true"><span>open interval</span></div>

      <article class="craft-plane craft-plane--interpretation" data-proof-step="interpretation" aria-labelledby="interpretation-title">
        <span>Interpretation</span>
        <h3 id="interpretation-title">{craftFixture.interpretation}</h3>
        <p>{craftFixture.uncertainty}</p>
        <dl>
          <div><dt>Evidence used</dt><dd>SRC-01 only</dd></div>
          <div><dt>Confidence</dt><dd>Not scored</dd></div>
          <div><dt>Next safe action</dt><dd>Open the linked source</dd></div>
        </dl>
      </article>

      <div class="craft-joint craft-joint--second" aria-hidden="true"><span>Witness Joint</span></div>

      <article
        class={`craft-plane craft-plane--review ${productPatternClassName("HumanReviewCheckpoint", { variant: "inverse", state: "review-needed" })}`}
        data-proof-step="review"
        aria-labelledby="review-title"
      >
        <span>Human review checkpoint</span>
        <h3 id="review-title">{craftFixture.status}</h3>
        <p>{craftFixture.decision}</p>
        <dl>
          <div><dt>Owner</dt><dd>{craftFixture.owner}</dd></div>
          <div><dt>Approval</dt><dd>Not recorded</dd></div>
        </dl>
        <a href="/patterns/humanreviewcheckpoint/">Inspect the checkpoint contract</a>
      </article>
    </div>
  </section>

  <footer class="craft-lab__footer">
    <p><strong>Identity:</strong> code-native geometry and provisional live wordmark.</p>
    <p><strong>Evidence:</strong> synthetic AX-031 fixture rendered with actual Sanchika contracts.</p>
    <p><strong>Validation:</strong> AI proxy evidence only · not user validated.</p>
  </footer>
</main>

<script is:inline>
  const root = document.querySelector("[data-craft-proof]");
  const button = root?.querySelector("[data-proof-advance]");
  const status = root?.querySelector("[data-proof-status]");
  const stages = ["source", "interpretation", "review"];
  button?.addEventListener("click", () => {
    if (!(root instanceof HTMLElement)) return;
    const current = root.dataset.stage || stages[0];
    const next = stages[(stages.indexOf(current) + 1) % stages.length];
    root.dataset.stage = next;
    if (status instanceof HTMLElement) status.textContent = `${next === "review" ? "Human review" : next[0].toUpperCase() + next.slice(1)} is in focus.`;
  });
</script>
