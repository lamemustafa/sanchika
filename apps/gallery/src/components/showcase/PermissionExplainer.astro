---
import { productPatternClassName } from "@sanchika/patterns";
import { primitiveClassName } from "@sanchika/primitives";
---

<aside class={productPatternClassName("PermissionExplainer", { variant: "panel", state: "required" })} aria-labelledby="permission-example-title">
  <div>
    <span>Permission required</span>
    <h2 id="permission-example-title">Allow a supported file download on the current portal page.</h2>
    <div class="sk-pattern-permission-explainer__facts">
      <span>Purpose: save the returned file locally</span>
      <span>Scope: current supported portal action; no unrelated page or file access</span>
      <span>Data touched: the supported portal response and browser download capability</span>
      <span>Data not touched: unrelated tabs, local files, or ComplyEaze workspace data</span>
      <span>If denied: no Pack download starts; use the portal's manual download path</span>
      <a class={primitiveClassName("Link")} href="https://github.com/lamemustafa/pack">Inspect public source and permission scope</a>
    </div>
  </div>
  <a class={primitiveClassName("Link")} href="/patterns/permissionexplainer/">Inspect permission contract</a>
</aside>
