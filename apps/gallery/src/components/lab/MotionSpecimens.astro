---
interface MotionSpecimen {
  readonly id: string;
  readonly title: string;
  readonly trigger: string;
  readonly behavior: string;
  readonly reduced: string;
  readonly candidate: string;
  readonly reuse: string;
  readonly c1Action: string;
}

interface Props {
  specimens: readonly MotionSpecimen[];
}

const { specimens } = Astro.props;
---

<section class="lab-motion-board" aria-labelledby="motion-board-title">
  <div class="lab-artifact-bar">
    <div>
      <span>Behavior contract</span>
      <strong id="motion-board-title">State stays legible when motion disappears.</strong>
    </div>
    <span class="lab-status-mark">CSS only</span>
  </div>
  <div class="lab-motion-board__grid">
    {specimens.map((specimen, index) => (
      <article class={`lab-motion-card lab-motion-card--${specimen.id}`}>
        <div class="lab-motion-card__demo" aria-label={`${specimen.title} visual specimen`}>
          {specimen.id === "focus" && <a href="#motion-notes">Keyboard focus evidence</a>}
          {specimen.id === "disclosure" && (
            <details>
              <summary>Why is review still required?</summary>
              <p>The assist creates a draft; the named reviewer owns the decision.</p>
            </details>
          )}
          {specimen.id === "progress" && (
            <div class="lab-motion-progress" role="status" aria-live="polite">
              <span><strong>Reading synthetic evidence</strong><small>CA review remains pending</small></span>
              <i aria-hidden="true"></i>
            </div>
          )}
          {specimen.id === "assist" && (
            <div class="lab-assist-note">
              <span>Draft suggestion</span>
              <p>Ask for the missing period evidence before forming a response position.</p>
              <small>Source: synthetic working note</small>
            </div>
          )}
        </div>
        <div class="lab-motion-card__copy">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h2>{specimen.title}</h2>
          <dl>
            <div><dt>Trigger</dt><dd>{specimen.trigger}</dd></div>
            <div><dt>Behavior</dt><dd>{specimen.behavior}</dd></div>
            <div><dt>Reduce</dt><dd>{specimen.reduced}</dd></div>
            <div><dt>Candidate</dt><dd>{specimen.candidate}</dd></div>
            <div><dt>Reuse</dt><dd>{specimen.reuse}</dd></div>
            <div><dt>C1 action</dt><dd>{specimen.c1Action}</dd></div>
          </dl>
        </div>
      </article>
    ))}
  </div>
  <div class="lab-motion-decisions" aria-labelledby="motion-decisions-title">
    <span>Candidate extraction</span>
    <h2 id="motion-decisions-title">Promote repetition; delete isolated effects.</h2>
    <p><strong>Repeated:</strong> 140ms focus/disclosure timing and the emphasized easing curve appear across the references.</p>
    <p><strong>One-off:</strong> the looping progress track and assisted-entry translation remain lab-only unless C1 proves a repeated product need.</p>
  </div>
  <p id="motion-notes" class="lab-motion-note">Reduced motion changes timing and transforms, never the visible state, source, or human-review boundary.</p>
</section>
