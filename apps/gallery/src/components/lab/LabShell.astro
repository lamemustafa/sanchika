---
import "@sanchika/tokens/theme.css";
import "@sanchika/primitives/styles.css";
import "@sanchika/patterns/styles.css";
import { primitiveClassName, textClassName } from "@sanchika/primitives";
import "../../styles/pattern-shell.css";

interface Props {
  title: string;
  description: string;
  routeId: string;
  mode: "complyeaze" | "axal" | "pack" | "tools" | "motion";
}

const { title, description, routeId, mode } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, "https://sanchika.complyeaze.com").href;
---

<!doctype html>
<html lang="en" data-sanchika-pattern-reference={routeId}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="data:," />
  </head>
  <body class:list={["sk-pattern-page", `sk-pattern-page--${mode}`, mode === "motion" && "lab-page--motion"]}>
    <a class="sk-pattern-skip-link" href="#sk-pattern-content">Skip to reference</a>
    <main id="sk-pattern-content" class={`sk-pattern-stage ${primitiveClassName("Container", { width: "wide" })}`} data-sanchika-example="synthetic" tabindex="-1">
      <slot />
    </main>
    <footer class={`sk-pattern-colophon ${primitiveClassName("Container", { width: "wide" })} ${primitiveClassName("Cluster", { gap: "md", justify: "between" })}`}>
      <p class={textClassName("caption")}><strong>Sanchika North Star lab</strong> · C1 review artifact · synthetic examples only</p>
      <p class={textClassName("caption")}>No taxpayer, client, portal-session, credential, or private repository data is used.</p>
    </footer>
  </body>
</html>
