---
import { primitiveClassName, textClassName } from "@sanchika/primitives";

interface Action {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  lede: string;
  primary?: Action;
  secondary?: Action;
  compact?: boolean;
}

const { eyebrow, title, lede, primary, secondary, compact = false } = Astro.props;
---

<header class:list={["lab-intro", compact && "lab-intro--compact"]}>
  <div class="lab-intro__copy">
    <p class={`lab-eyebrow ${textClassName("eyebrow")}`}>{eyebrow}</p>
    <h1 class={textClassName("display")}>{title}</h1>
    <p class={`lab-lede ${textClassName("lead")}`}>{lede}</p>
    {(primary || secondary) && (
      <div class={`lab-actions ${primitiveClassName("Cluster", { gap: "md" })}`} aria-label="Reference actions">
        {primary && <a class={`lab-action-link lab-action-link--brand ${primitiveClassName("Link")}`} href={primary.href}>{primary.label}</a>}
        {secondary && <a class={`lab-action-link lab-action-link--neutral ${primitiveClassName("Link")}`} href={secondary.href}>{secondary.label}</a>}
      </div>
    )}
  </div>
  <slot />
</header>
