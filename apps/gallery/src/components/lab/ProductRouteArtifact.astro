---
import { primitiveClassName, textClassName } from "@sanchika/primitives";
import { productPatternClassName } from "@sanchika/patterns";

interface ProductRoute {
  readonly label: string;
  readonly name: string;
  readonly job: string;
  readonly boundary: string;
  readonly href: string;
  readonly signal: string;
}

interface QueueItem {
  readonly id: string;
  readonly title: string;
  readonly entity: string;
  readonly state: string;
  readonly source: string;
  readonly owner: string;
  readonly due: string;
  readonly tone: string;
}

interface Props {
  routes: readonly ProductRoute[];
  queue: readonly QueueItem[];
}

const { routes, queue } = Astro.props;
const [primaryRoute, ...secondaryRoutes] = routes;
---

<section id="product-routes" class={`${productPatternClassName("ProductRouteMap", { variant: "family", state: "default" })} ${primitiveClassName("Surface", { variant: "inverse", padding: "none" })}`} aria-labelledby="product-route-title">
  <div class={`sk-pattern-artifact-bar ${primitiveClassName("Cluster", { gap: "md", justify: "between" })}`}>
    <div>
      <span>Choose by operating boundary</span>
      <strong id="product-route-title">Your work decides the route.</strong>
    </div>
    <span class="sk-pattern-status-mark">Synthetic reference</span>
  </div>

  {primaryRoute && (
    <article class="sk-pattern-product-route-map__primary">
      <div class="sk-pattern-product-route-map__primary__copy">
        <p class={textClassName("eyebrow")}>{primaryRoute.label}</p>
        <h2 class={textClassName("display")}>{primaryRoute.name}</h2>
        <strong>{primaryRoute.signal}</strong>
        <p>{primaryRoute.job}</p>
        <span>{primaryRoute.boundary}</span>
        <a class={primitiveClassName("Link")} href={primaryRoute.href}>Inspect the Axal review desk <span aria-hidden="true">→</span></a>
      </div>
      <div class={`sk-pattern-product-route-map__queue ${primitiveClassName("Stack", { gap: "sm" })}`} aria-label="Synthetic Axal review queue">
        <p>Review queue</p>
        {queue.map((item) => (
          <article data-tone={item.tone}>
            <div>
              <span>{item.id}</span>
              <strong>{item.title}</strong>
            </div>
            <p>{item.state}</p>
            <small>{item.entity} · {item.due}</small>
          </article>
        ))}
      </div>
    </article>
  )}

  <div class="sk-pattern-product-route-map__secondary">
    {secondaryRoutes.map((route) => (
      <article>
        <div>
          <p class={textClassName("eyebrow")}>{route.label}</p>
          <h2>{route.name}</h2>
        </div>
        <strong>{route.signal}</strong>
        <p>{route.job}</p>
        <span>{route.boundary}</span>
        <a class={primitiveClassName("Link")} href={route.href}>Inspect {route.name} proof <span aria-hidden="true">→</span></a>
      </article>
    ))}
  </div>
  <footer class="sk-pattern-product-route-map__colophon">
    <span>Design evidence</span>
    <a class={primitiveClassName("Link")} href="/patterns/">Sanchika pattern contracts</a>
  </footer>
</section>
