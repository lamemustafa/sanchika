---
import { productPatternClassName } from "@sanchika/patterns";
import { primitiveClassName } from "@sanchika/primitives";

interface Fact {
  label: string;
  value: string;
}

interface BaseProps {
  label: string;
  statement: string;
  facts?: readonly Fact[];
  tone?: "workspace" | "local" | "draft" | "assist";
}

interface TrustBoundaryProps extends BaseProps {
  pattern: "TrustBoundary";
  neverCrosses: string;
  actionOwner: string;
  safeAction: string;
  sourceLink: { readonly label: string; readonly href: string };
}

interface LocalBoundaryProps extends BaseProps {
  pattern: "LocalBoundaryBanner";
  sourceLink?: { readonly label: string; readonly href: string };
}

interface GenericBoundaryProps extends BaseProps {
  pattern?: undefined;
  sourceLink?: { readonly label: string; readonly href: string };
}

type Props = TrustBoundaryProps | LocalBoundaryProps | GenericBoundaryProps;

const props = Astro.props;
const { label, statement, facts = [], tone = "workspace", pattern, sourceLink } = props;
const trustTone = tone === "assist" ? "inverse" : tone;
const boundaryClass = pattern === "LocalBoundaryBanner"
  ? productPatternClassName("LocalBoundaryBanner", { variant: tone === "local" ? "local" : "draft", state: "local-only" })
  : pattern === "TrustBoundary"
    ? productPatternClassName("TrustBoundary", { variant: trustTone, state: tone === "local" || tone === "draft" ? "local-only" : undefined })
    : `${primitiveClassName("Surface", { variant: "inset", padding: "lg" })} ${primitiveClassName("Grid", { columns: "2", gap: "lg" })}`;
const visibleFacts = props.pattern === "TrustBoundary"
  ? [
      ...facts,
      { label: "Never crosses", value: props.neverCrosses },
      { label: "Action owner", value: props.actionOwner },
      { label: "Safe action", value: props.safeAction },
    ]
  : facts;
---

<aside class={boundaryClass} aria-label={label}>
  <div class="sk-pattern-trust-boundary__claim">
    <span>{label}</span>
    <strong>{statement}</strong>
    {sourceLink && <a class={primitiveClassName("Link")} href={sourceLink.href}>{sourceLink.label}</a>}
  </div>
  {visibleFacts.length > 0 && (
    <dl class="sk-pattern-trust-boundary__facts">
      {visibleFacts.map((fact) => (
        <div>
          <dt>{fact.label}</dt>
          <dd>{fact.value}</dd>
        </div>
      ))}
    </dl>
  )}
</aside>
