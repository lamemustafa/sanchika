---
import type { LabTool, ToolCategory } from "../../content/lab/references";
import { primitiveClassName, textClassName } from "@sanchika/primitives";

interface Props {
  tools: readonly LabTool[];
  axalHref: string;
  instanceId: string;
}

const { tools, axalHref, instanceId } = Astro.props;
const categories = [...new Set(tools.map((tool) => tool.category))] as ToolCategory[];
const titleId = `${instanceId}-title`;
const statusId = `${instanceId}-status`;
const searchId = `${instanceId}-search`;
const noteId = `${instanceId}-note`;
const escalationId = `${instanceId}-escalation-title`;
---

<section class={`lab-directory ${primitiveClassName("Surface", { variant: "default", padding: "none" })}`} aria-labelledby={titleId} data-tool-directory data-tool-instance={instanceId}>
  <div class={`lab-directory__head ${primitiveClassName("Cluster", { gap: "lg", align: "end", justify: "between" })}`}>
    <div>
      <span>Local tool index</span>
      <h2 id={titleId} class={textClassName("heading")}>Search by the work on your desk.</h2>
    </div>
    <p id={statusId} data-sk-result-status role="status" aria-live="polite" aria-atomic="true"><strong data-tool-count>{tools.length}</strong> draft tools</p>
  </div>

  <form class={`lab-directory__search ${primitiveClassName("SearchField", { size: "lg" })}`} role="search" data-tool-search-form data-has-value="false">
    <label for={searchId}>What do you need to prepare?</label>
    <div class="lab-directory__search-control sk-search-field__control">
      <span class="sk-search-field__icon" aria-hidden="true">⌕</span>
      <input
        id={searchId}
        name="query"
        type="search"
        placeholder="Try notice, GSTR-2B, dates, evidence…"
        autocomplete="off"
        aria-describedby={`${noteId} ${statusId}`}
        data-tool-search
      />
      <button class="sk-search-field__clear" type="button" aria-label="Clear tool search and category filter" data-tool-clear>Clear</button>
    </div>
    <p id={noteId} data-sk-search-hint>Filtering happens only in this browser. Nothing is uploaded.</p>
  </form>

  <div class={`lab-directory__filters ${primitiveClassName("Cluster", { gap: "sm" })}`} aria-label="Tool categories" data-tool-filters hidden>
    <button type="button" aria-pressed="true" data-tool-category="all">All work</button>
    {categories.map((category) => (
      <button type="button" aria-pressed="false" data-tool-category={category}>{category}</button>
    ))}
  </div>

  <noscript><p class={`lab-directory__noscript ${primitiveClassName("InlineStatus", { tone: "info" })}`}><span class="sk-inline-status__marker" aria-hidden="true">i</span><span>JavaScript is off, so the complete tool list remains visible.</span></p></noscript>

  <div class="lab-directory__results" data-tool-results>
    {tools.map((tool, index) => (
      <article
        data-tool-card
        data-category={tool.category}
        data-search={[tool.name, tool.category, tool.job, ...tool.keywords].join(" ").toLowerCase()}
      >
        <div class="lab-tool-card__index">{String(index + 1).padStart(2, "0")}</div>
        <div class="lab-tool-card__main">
          <span>{tool.category}</span>
          <h3>{tool.name}</h3>
          <p>{tool.job}</p>
        </div>
        <dl class={primitiveClassName("Grid", { columns: "3", gap: "md" })}>
          <div><dt>Input</dt><dd>{tool.input}</dd></div>
          <div><dt>Output</dt><dd>{tool.output}</dd></div>
          <div><dt>Review</dt><dd>{tool.review}</dd></div>
        </dl>
      </article>
    ))}
  </div>

  <div class={`lab-directory__empty ${primitiveClassName("EmptyState", { kind: "filtered" })}`} data-empty-kind="filtered" data-tool-empty hidden>
    <span>0 matches</span>
    <h3>No local draft tool matches that work.</h3>
    <p>Clear the search or choose another category. The query never leaves this browser.</p>
    <div class="sk-empty-state__actions"><button class={primitiveClassName("Button", "neutral", "md")} type="button" data-tool-reset>Reset directory</button></div>
  </div>

  <aside class="lab-directory__escalation" aria-labelledby={escalationId}>
    <span>Recurring or saved work</span>
    <h3 id={escalationId}>Move continuing review into Axal.</h3>
    <p>Use a local tool for a bounded draft. Use Axal when evidence, ownership, review state, or a continuing client record must remain visible.</p>
    <a class={primitiveClassName("Link")} href={axalHref}>Open the synthetic Axal review desk <span aria-hidden="true">→</span></a>
  </aside>
</section>

<script is:inline data-sanchika-lab-script="tool-filter">
  for (const directory of document.querySelectorAll("[data-tool-directory]")) {
    const form = directory.querySelector("[data-tool-search-form]");
    const input = directory.querySelector("[data-tool-search]");
    const clear = directory.querySelector("[data-tool-clear]");
    const filters = directory.querySelector("[data-tool-filters]");
    const cards = [...directory.querySelectorAll("[data-tool-card]")];
    const count = directory.querySelector("[data-tool-count]");
    const empty = directory.querySelector("[data-tool-empty]");
    const reset = directory.querySelector("[data-tool-reset]");
    let category = "all";
    let announcementTimer;
    let composing = false;

    filters.hidden = false;

    const applyFilters = ({ announce = true } = {}) => {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      clear.hidden = query.length === 0;
      form.dataset.hasValue = String(query.length > 0);

      for (const card of cards) {
        const categoryMatches = category === "all" || card.dataset.category === category;
        const queryMatches = !query || card.dataset.search.includes(query);
        card.hidden = !(categoryMatches && queryMatches);
        if (!card.hidden) visible += 1;
      }

      empty.hidden = visible !== 0;
      form.dataset.noResults = String(visible === 0);
      if (announce) {
        clearTimeout(announcementTimer);
        form.dataset.filtering = "true";
        count.parentElement.setAttribute("aria-busy", "true");
        announcementTimer = setTimeout(() => { count.textContent = String(visible); delete form.dataset.filtering; count.parentElement.removeAttribute("aria-busy"); }, 180);
      } else {
        count.textContent = String(visible);
      }
    };

    const resetDirectory = () => {
      input.value = "";
      category = "all";
      for (const candidate of filters.querySelectorAll("[data-tool-category]")) candidate.setAttribute("aria-pressed", String(candidate.dataset.toolCategory === "all"));
      applyFilters();
      input.focus();
    };

    form.addEventListener("submit", (event) => event.preventDefault());
    input.addEventListener("compositionstart", () => { composing = true; });
    input.addEventListener("compositionend", () => { composing = false; applyFilters(); });
    input.addEventListener("input", (event) => { if (!composing && !event.isComposing) applyFilters(); });
    input.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || input.value.length === 0) return;
      event.preventDefault();
      resetDirectory();
    });
    clear.addEventListener("click", () => {
      resetDirectory();
    });
    reset.addEventListener("click", resetDirectory);
    filters.addEventListener("click", (event) => {
      if (!(event.target instanceof Node)) return;
      const target = event.target instanceof Element ? event.target : event.target.parentElement;
      const button = target?.closest("[data-tool-category]");
      if (!button) return;
      category = button.dataset.toolCategory;
      for (const candidate of filters.querySelectorAll("[data-tool-category]")) {
        candidate.setAttribute("aria-pressed", String(candidate === button));
      }
      applyFilters();
    });
    applyFilters({ announce: false });
  }
</script>
