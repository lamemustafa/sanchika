---
import { formatGSTINDisplay, formatIndianCurrency, formatIndianDate, formatIndianDateTime, formatIndianNumber, formatPANDisplay, formatPercentage, primitiveClassName, textClassName } from "@sanchika/primitives";

const rows = [
  { period: "Example period A", date: formatIndianDate("2026-04-30"), amount: formatIndianCurrency(1234567.5), rate: formatPercentage(0.18) },
  { period: "Example period B", date: formatIndianDate("2026-05-31"), amount: formatIndianCurrency(-245000), rate: formatPercentage(12.5, { input: "percent" }) },
  { period: "Example period C", date: formatIndianDate("2026-06-30"), amount: formatIndianCurrency(10000000, { display: "compact" }), rate: formatPercentage(0.005) },
] as const;
---

<section class={primitiveClassName("Section", { space: "lg", boundary: "bordered" })} aria-labelledby="s5-data-title">
  <div class={primitiveClassName("Stack", { gap: "lg" })}>
    <nav class={primitiveClassName("Breadcrumb")} aria-label="Breadcrumb"><ol class="sk-breadcrumb__list"><li class="sk-breadcrumb__item"><a class={primitiveClassName("Link")} href="/">Gallery</a><span class="sk-breadcrumb__separator" aria-hidden="true">/</span></li><li class="sk-breadcrumb__item"><a class={primitiveClassName("Link")} href="/primitives/foundations/">Primitives</a><span class="sk-breadcrumb__separator" aria-hidden="true">/</span></li><li class="sk-breadcrumb__item" aria-current="page">Search, state, and feedback</li></ol></nav>
    <div><p class={textClassName("eyebrow")}>Navigation and data</p><h2 id="s5-data-title" class={textClassName("heading")}>Indian display rules stay exact unless compact mode is requested.</h2></div>
    <div class="s5-stat-grid">
      <dl class={primitiveClassName("Stat", { alignment: "start" })}><dt class="sk-stat__label">Synthetic taxable value</dt><dd class="sk-stat__value">{formatIndianCurrency(12345678.9)}</dd><dd class="sk-stat__delta" data-delta-direction="increase">Increase 2.4%</dd><dd class="sk-stat__meta">Source reviewed {formatIndianDate("2026-07-14")}</dd></dl>
      <dl class={primitiveClassName("Stat", { alignment: "start" })}><dt class="sk-stat__label">Exact records</dt><dd class="sk-stat__value">{formatIndianNumber(12345678)}</dd><dd class="sk-stat__delta">No comparison supplied</dd></dl>
      <dl class={primitiveClassName("Stat", { alignment: "start" })}><dt class="sk-stat__label">Compact display</dt><dd class="sk-stat__value">{formatIndianNumber(12500000, { display: "compact" })}</dd><dd class="sk-stat__meta">Explicit compact option</dd></dl>
    </div>
    <dl class="s5-formatter-ledger">
      <div><dt>Date-only</dt><dd>{formatIndianDate("2024-02-29")}</dd></div>
      <div><dt>Date-time</dt><dd>{formatIndianDateTime("2026-07-14T00:00:00Z", { timeZone: "Asia/Kolkata" })}</dd></div>
      <div><dt>Percentage</dt><dd>{formatPercentage(18, { input: "percent" })}</dd></div>
      <div><dt>PAN display</dt><dd>{formatPANDisplay("abcde1234f")}</dd></div>
      <div><dt>GSTIN display</dt><dd>{formatGSTINDisplay("27abcde1234f1z5")}</dd></div>
    </dl>
    <div class={`s5-table-fluid-proof ${primitiveClassName("TableShell", { density: "comfortable", header: "sticky" })}`} data-density="comfortable" data-sticky-header="true" data-zoom-proof="200 400">
      <p class="sk-table-shell__affordance">Priority data stays first. Scroll horizontally if source detail exceeds the viewport.</p>
      <div class="sk-table-shell__viewport">
        <table><caption>Synthetic filing summary</caption><thead><tr><th scope="col">Period</th><th scope="col">Display date</th><th scope="col" class="sk-table-shell__numeric">Amount</th><th scope="col" class="sk-table-shell__numeric">Rate</th><th scope="col">Review state</th></tr></thead><tbody>{rows.map((row) => <tr><th scope="row">{row.period}</th><td>{row.date}</td><td class="sk-table-shell__numeric">{row.amount}</td><td class="sk-table-shell__numeric">{row.rate}</td><td>CA review required</td></tr>)}</tbody></table>
      </div>
    </div>
    <div class={`s5-table-overflow-proof ${primitiveClassName("TableShell", { density: "compact", header: "static" })}`} data-density="compact">
      <p id="s5-table-overflow-label" class="sk-table-shell__affordance">Compact overflow proof — use the focused region to reach every synthetic source column.</p>
      <div class="sk-table-shell__viewport" tabindex="0" aria-labelledby="s5-table-overflow-label">
        <table><caption>Synthetic compact source references</caption><thead><tr><th scope="col">Reference</th><th scope="col">Source description</th><th scope="col">Display date</th><th scope="col" class="sk-table-shell__numeric">Amount</th></tr></thead><tbody><tr><th scope="row">S5-SOURCE-001</th><td>Long synthetic source description retained for horizontal-reachability evidence</td><td>{formatIndianDate("2026-07-14")}</td><td class="sk-table-shell__numeric">{formatIndianCurrency(1234567.5)}</td></tr></tbody></table>
      </div>
    </div>
    <p class={textClassName("caption")}>PAN and GSTIN helpers group display text only. They do not validate checksums, registration status, or identity.</p>
  </div>
</section>
