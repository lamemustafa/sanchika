---
import { productPatternClassName } from "@sanchika/patterns";
import { currentStableRelease, currentStableReleaseUrl, noNextReleaseAnnouncement } from "../content/site";
---

<section class="status-summary" aria-labelledby="status-title">
  <div class="section-heading">
    <div><p class="eyebrow">Current truth</p><h2 id="status-title">Proven, limited, current.</h2></div>
    <p>Evidence is useful only when its boundary is as visible as its result.</p>
  </div>
  <div class="status-summary__grid">
    <article data-status="proven"><span>Proven</span><h3>Contracts build and travel.</h3><ul><li>Deterministic tokens</li><li>Three package artifacts</li><li>Static gallery and consumer checks</li><li>Four synthetic reference compositions</li></ul></article>
    <article data-status="limited"><span>Limited</span><h3>Proof is deliberately bounded.</h3><ul><li>Synthetic examples</li><li>No universal framework runtime</li><li>Consumer adoption remains incomplete</li><li>Physical assistive-technology testing still required</li></ul></article>
    <article data-status="current"><span>Current release</span><h3>v{currentStableRelease} is the stable package set.</h3><ul><li>GitHub tarball artifacts</li><li>No npm publication</li><li>{noNextReleaseAnnouncement}</li></ul></article>
  </div>
  <aside class={productPatternClassName("ReleaseStatusBanner", { variant: "notice", state: "current" })} aria-label="Release status">
    <strong>Current stable release: v{currentStableRelease}</strong>
    <span>GitHub artifacts cover tokens, primitives, and patterns. Source manifests remain private at 0.0.0, and the packages are not published to npm. {noNextReleaseAnnouncement}</span>
    <a href={currentStableReleaseUrl}>Inspect v{currentStableRelease} release evidence</a>
  </aside>
</section>
