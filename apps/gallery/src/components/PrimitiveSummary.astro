---
import { primitiveGroups, primitiveSpecs } from "@sanchika/primitives";

function summaryFor(primitive: (typeof primitiveSpecs)[number]): string {
  if (primitive.name === "Badge") return primitive.tones.map(titleCase).join(", ");
  if (primitive.name === "Card") return "Static and focusable evidence containers";
  return primitive.requiredStates
    .map((state) => state === "focus-visible" ? "focus" : state === "error" ? "invalid with described error" : state)
    .map(titleCase)
    .join(", ");
}

function titleCase(value: string): string {
  return `${value.charAt(0).toUpperCase()}${value.slice(1)}`;
}
---

<section class="sk-gallery-matrix" aria-labelledby="gallery-matrix-title">
  <div>
    <h2 id="gallery-matrix-title">Reusable states must show proof, not decoration.</h2>
    <p>Each primitive keeps the interaction state explicit enough for a CA workflow, browser-local tool, or review surface to adopt without inventing hidden behavior.</p>
  </div>
  <div class="sk-gallery-matrix-grid">
    {primitiveGroups.legacy.map((primitive) => <article data-sk-primitive-summary={primitive.name}><span>{primitive.name}</span><strong>{summaryFor(primitive)}</strong></article>)}
  </div>
</section>
