---
import { motionAssistClassName, primitiveClassName, textClassName } from "@sanchika/primitives";
---

<section class={primitiveClassName("Section", { space: "lg", boundary: "bordered" })} aria-labelledby="s5-process-title">
  <div class={primitiveClassName("Stack", { gap: "lg" })}>
    <div><p class={textClassName("eyebrow")}>Process and recovery</p><h2 id="s5-process-title" class={textClassName("heading")}>Native state stays visible without a package runtime.</h2></div>
    <div class="s5-process-grid">
      <div class={primitiveClassName("Stack", { gap: "md" })}>
        <div class={primitiveClassName("Progress", { state: "determinate" })}><div class="sk-progress__header"><span id="s5-progress-label">Checking synthetic sources</span><span id="s5-progress-value" class="sk-progress__value">3 of 5</span></div><progress value="3" max="5" aria-labelledby="s5-progress-label" aria-describedby="s5-progress-value">3 of 5</progress></div>
        <div class={primitiveClassName("Progress", { state: "indeterminate" })} data-progress-state="indeterminate"><div class="sk-progress__header"><span id="s5-pending-label">Waiting for local review</span><span id="s5-pending-value" class="sk-progress__value">Pending</span></div><progress aria-labelledby="s5-pending-label" aria-describedby="s5-pending-value"></progress></div>
        <div class={primitiveClassName("Progress", { state: "complete" })} data-progress-state="complete"><div class="sk-progress__header"><span id="s5-complete-label">Synthetic source check complete</span><span id="s5-complete-value" class="sk-progress__value">5 of 5 · Complete</span></div><progress value="5" max="5" aria-labelledby="s5-complete-label" aria-describedby="s5-complete-value">5 of 5</progress></div>
        <div class={primitiveClassName("Progress", { state: "error" })} data-progress-state="error"><div class="sk-progress__header"><span id="s5-progress-error-label">Synthetic source check stopped</span><span id="s5-progress-error-value" class="sk-progress__value">3 of 5 · Review source and retry</span></div><progress value="3" max="5" aria-labelledby="s5-progress-error-label" aria-describedby="s5-progress-error-value">3 of 5</progress></div>
        <ol class={primitiveClassName("Stepper", { orientation: "horizontal" })}>
          <li class="sk-stepper__step" data-step-state="complete"><span class="sk-stepper__marker" aria-hidden="true">✓</span><span><strong>Source received</strong><br />Complete</span></li>
          <li class="sk-stepper__step" aria-current="step"><span class="sk-stepper__marker">2</span><span><strong>CA review</strong><br />Current step</span></li>
          <li class="sk-stepper__step" data-step-state="upcoming"><span class="sk-stepper__marker">3</span><span><strong>Decision</strong><br />Upcoming</span></li>
          <li class="sk-stepper__step" data-step-state="blocked"><span class="sk-stepper__marker" aria-hidden="true">!</span><span><strong>Evidence handoff</strong><br />Blocked — attach the missing synthetic source</span></li>
        </ol>
      </div>
      <div class={primitiveClassName("Stack", { gap: "md" })}>
        <details class={primitiveClassName("Disclosure")}><summary class="sk-disclosure__summary">Closed source detail</summary><div class={`sk-disclosure__content ${motionAssistClassName("disclosure-continuity")}`}><p>This content is native and available without JavaScript.</p></div></details>
        <details class={primitiveClassName("Disclosure")} open><summary class="sk-disclosure__summary">Open long-content guidance</summary><div class={`sk-disclosure__content ${motionAssistClassName("disclosure-continuity")}`}><p>M/s Shree Venkateshwara Industrial Components and Professional Services Private Limited remains readable without height animation or clipped focusable content.</p><a class={primitiveClassName("Link")} href="#s5-contract-ledger">Read contract responsibilities</a></div></details>
        <p class={textClassName("caption")} data-disclosure-nested-guidance>Keep disclosures as siblings. Do not place an interactive summary inside another summary.</p>
        <div class="s5-copy-fixtures">
          <div data-copy-fixture><code data-copy-source>sha256:synthetic-s5-proof</code><button class={`${primitiveClassName("CopyButton", { state: "idle", size: "sm" })} ${motionAssistClassName("copy-confirmation")}`} type="button" aria-label="Copy synthetic checksum" data-copy-button><span class="sk-copy-button__label">Copy checksum</span></button><span class="sk-copy-button__status" role="status" aria-live="polite" aria-atomic="true"></span></div>
          <div data-copy-fixture><code data-copy-source>S5-FAILURE-FIXTURE</code><button class={primitiveClassName("CopyButton", { state: "idle", size: "sm" })} type="button" aria-label="Exercise denied copy fixture" data-copy-button data-copy-denied><span class="sk-copy-button__label">Try denied copy</span></button><span class="sk-copy-button__status" role="status" aria-live="polite" aria-atomic="true"></span></div>
          <div data-copy-fixture><code data-copy-source></code><button class={primitiveClassName("CopyButton", { state: "idle", size: "sm" })} type="button" aria-label="Copy unavailable value" data-copy-button disabled><span class="sk-copy-button__label">No value to copy</span></button><span class="sk-copy-button__status" role="status" aria-live="polite" aria-atomic="true"></span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline data-sanchika-gallery-script="s5-copy-button">
  for (const button of document.querySelectorAll("[data-copy-button]")) {
    const label = button.querySelector(".sk-copy-button__label");
    const fixture = button.closest("[data-copy-fixture]");
    const target = fixture?.querySelector("[data-copy-source]");
    const status = fixture?.querySelector(".sk-copy-button__status");
    const idleLabel = label?.textContent ?? "Copy";
    let resetTimer;
    let pending = false;
    if (!label || !status || !target?.textContent?.trim()) button.disabled = true;
    button.addEventListener("click", async () => {
      if (pending || button.disabled || !label || !status || !target) return;
      pending = true;
      clearTimeout(resetTimer);
      button.setAttribute("aria-busy", "true");
      try {
        if (button.hasAttribute("data-copy-denied")) throw new Error("Synthetic clipboard denial");
        if (!navigator.clipboard?.writeText) throw new Error("Clipboard API unavailable");
        await navigator.clipboard.writeText(target.textContent);
        button.dataset.copyState = "copied";
        label.textContent = "Copied";
        status.textContent = "Copied to clipboard.";
      } catch {
        button.dataset.copyState = "failed";
        label.textContent = "Copy failed";
        status.textContent = "Copy failed. Select and copy the visible value manually.";
      }
      pending = false;
      button.removeAttribute("aria-busy");
      resetTimer = setTimeout(() => { button.dataset.copyState = "idle"; label.textContent = idleLabel; status.textContent = ""; }, 1600);
    });
  }
</script>
