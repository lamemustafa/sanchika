---
import DirectionLab from "../../components/craft/DirectionLab.astro";
import {
  craftTerritories,
  craftTerritoryLabels,
  type CraftTerritory,
} from "../../content/craft-lab";
import identityCss from "../../styles/identity.css?raw";
import craftLabCss from "../../styles/craft-lab.css?raw";
import tokenCss from "../../../../../packages/tokens/src/theme.css?raw";
import fontDataUrl from "../../assets/fonts/AnekDevanagari-Variable-subset.woff2?inline";

export function getStaticPaths() {
  if (import.meta.env.SANCHIKA_CRAFT_LAB !== "1") return [];
  return craftTerritories.map((territory) => ({ params: { territory }, props: { territory } }));
}

interface Props {
  territory: CraftTerritory;
}

const { territory } = Astro.props;
const label = craftTerritoryLabels[territory];
const labCss = `${tokenCss}\n${identityCss}\n${craftLabCss}`.replace(
  '../assets/fonts/AnekDevanagari-Variable-subset.woff2',
  fontDataUrl,
);
---

<!doctype html>
<html lang="en" data-sanchika-gallery-document="internal-craft-lab">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <title>{label} | Sanchika internal craft lab</title>
    <meta name="description" content={`Internal code-native Sanchika territory: ${label}.`} />
    <style is:inline set:html={labCss}></style>
  </head>
  <body><DirectionLab {territory} /></body>
</html>
