---
import { motionAssistUtilities } from "@sanchika/primitives";
import MotionAssistProof from "../../components/MotionAssistProof.astro";
import PageIntro from "../../components/PageIntro.astro";
import GalleryLayout from "../../layouts/GalleryLayout.astro";
---
<GalleryLayout title="Motion | Sanchika" description="Sanchika CSS-first motion-assist utilities and reduced-motion behavior.">
  <main id="main-content" class="site-main docs-page" tabindex="-1">
    <PageIntro eyebrow="Foundations / motion" title="Motion confirms state. It never supplies meaning." description="Finite CSS-first utilities acknowledge focus, press, disclosure, status, and loading while the settled text, source, and boundary remain authoritative." meta={`${motionAssistUtilities.length} package utilities · prefers-reduced-motion covered`} />
    <MotionAssistProof />
    <section class="doc-section" aria-labelledby="motion-use-title"><h2 id="motion-use-title">Use and avoid</h2><div class="doc-grid doc-grid--2"><article class="doc-card"><span>Use</span><p>Short, one-pass acknowledgement where spatial continuity or settled status benefits comprehension.</p></article><article class="doc-card"><span>Avoid</span><p>Whole-page reveals, ambient loops, large travel, critical-action choreography, or movement as the only focus/status cue.</p></article></div></section>
  </main>
</GalleryLayout>
