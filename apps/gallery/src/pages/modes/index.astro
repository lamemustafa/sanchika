---
import PageIntro from "../../components/PageIntro.astro";
import { modes } from "../../content/site";
import GalleryLayout from "../../layouts/GalleryLayout.astro";
---
<GalleryLayout title="Product modes | Sanchika" description="Four Sanchika product modes with distinct density, proof objects, and trust boundaries.">
  <main id="main-content" class="site-main docs-page" tabindex="-1">
    <PageIntro eyebrow="Product modes" title="One evidence grammar. Four different kinds of confidence." description="ComplyEaze publishes and routes. Axal carries professional review. Pack proves local custody. Tools produces browser-local drafts. Sanchika is the system beneath them, not a peer product." meta="Four modes · no fifth Sanchika product mode" />
    <section class="doc-section" aria-labelledby="mode-index-title"><h2 id="mode-index-title">Compare operating character</h2><div class="mode-comparison-table-wrap" role="region" aria-labelledby="mode-index-title" tabindex="0"><table class="mode-comparison-table"><thead><tr><th scope="col">Mode</th><th scope="col">Work character</th><th scope="col">Dominant proof</th><th scope="col">Persistence</th><th scope="col">Meaningful edge</th></tr></thead><tbody>{modes.map((mode) => <tr><th scope="row"><a href={`/modes/${mode.id}/`}>{mode.label}</a></th><td>{mode.density}</td><td>{mode.proof}</td><td>{mode.persistence}</td><td>{mode.edgeState}</td></tr>)}</tbody></table></div></section>
    <section class="doc-section one-record" aria-labelledby="one-record-title"><div><p class="eyebrow">One record, four rooms</p><h2 id="one-record-title">AX-031 changes shape without losing responsibility.</h2><p>The record identifier is intentionally repeated; the product job, persistence boundary, and proof object change around it.</p></div><div class="one-record__grid">{modes.map((mode) => <article data-mode={mode.id}><span>AX-031 · {mode.label}</span><strong>{mode.recordMoment}</strong><a href={`/modes/${mode.id}/`}>Inspect this mode</a></article>)}</div></section>
  </main>
</GalleryLayout>
