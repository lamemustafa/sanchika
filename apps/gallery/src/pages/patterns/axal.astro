---
import { productPatternGroups } from "@sanchika/patterns";
import { primitiveClassName } from "@sanchika/primitives";
import BoundaryBanner from "../../components/lab/BoundaryBanner.astro";
import LabIntro from "../../components/lab/LabIntro.astro";
import ReviewDesk from "../../components/lab/ReviewDesk.astro";
import PatternContractLedger from "../../components/patterns/PatternContractLedger.astro";
import PatternReferenceHeader from "../../components/patterns/PatternReferenceHeader.astro";
import { auditTrail, reviewEvidence, reviewQueue } from "../../content/lab/references";
import GalleryLayout from "../../layouts/GalleryLayout.astro";

const group = productPatternGroups[1];
---

<GalleryLayout title="Axal workspace patterns | Sanchika" description="Rendered Sanchika patterns for evidence-led professional review workspaces." canonical="https://sanchika.complyeaze.com/patterns/axal/" dataFavicon>
  <main id="gallery-content" class={`pattern-reference-main ${primitiveClassName("Container", { width: "wide" })}`} data-sanchika-pattern-group={group.name} data-sanchika-example="synthetic">
    <PatternReferenceHeader eyebrow="Axal professional workspace" title="Evidence, ownership, and judgment in one review path." description={group.visualCharacter} />
    <section class="pattern-reference-example" aria-label="Axal pattern composition">
      <BoundaryBanner label="Synthetic workspace boundary" statement="Saved review context is visible; a named CA owns the judgment." facts={[{ label: "Data", value: "Synthetic only" }, { label: "Assist", value: "Draft, never approval" }, { label: "Decision", value: "Named reviewer" }]} sourceLink={{ label: "Inspect the boundary contract", href: "#pattern-contract-ledger-title" }} />
      <LabIntro eyebrow="Dense professional workspace" title="See what needs action, why, and what still needs human review." lede="Queue, evidence, due state, owner, audit events, and the checkpoint remain visible without turning the desk into a generic dashboard." compact headingLevel="h2" />
      <ReviewDesk queue={reviewQueue} evidence={reviewEvidence} audit={auditTrail} />
    </section>
    <PatternContractLedger contracts={group.patterns} />
  </main>
</GalleryLayout>
