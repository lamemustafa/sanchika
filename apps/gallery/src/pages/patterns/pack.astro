---
import { productPatternGroups } from "@sanchika/patterns";
import { primitiveClassName } from "@sanchika/primitives";
import BoundaryBanner from "../../components/lab/BoundaryBanner.astro";
import CustodyFlow from "../../components/lab/CustodyFlow.astro";
import LabIntro from "../../components/lab/LabIntro.astro";
import PermissionExplainer from "../../components/lab/PermissionExplainer.astro";
import PatternContractLedger from "../../components/patterns/PatternContractLedger.astro";
import PatternReferenceHeader from "../../components/patterns/PatternReferenceHeader.astro";
import { custodyFacts, custodyStages } from "../../content/lab/references";
import GalleryLayout from "../../layouts/GalleryLayout.astro";

const group = productPatternGroups[2];
---

<GalleryLayout title="Pack local utility patterns | Sanchika" description="Rendered Sanchika custody and permission patterns for local browser utilities." canonical="https://sanchika.complyeaze.com/patterns/pack/" dataFavicon>
  <main id="gallery-content" class={`pattern-reference-main ${primitiveClassName("Container", { width: "wide" })}`} data-sanchika-pattern-group={group.name} data-sanchika-example="synthetic">
    <PatternReferenceHeader eyebrow="Pack local utility" title="Custody, permission, and destination before action." description={group.visualCharacter} />
    <section class="pattern-reference-example" aria-label="Pack pattern composition">
      <BoundaryBanner label="Local-first boundary" statement="The supported file moves from the portal response to this device." tone="local" facts={[{ label: "Account", value: "Not required" }, { label: "Upload", value: "No ComplyEaze handoff" }, { label: "Telemetry", value: "None in this flow" }]} sourceLink={{ label: "Inspect the boundary contract", href: "#pattern-contract-ledger-title" }} />
      <LabIntro eyebrow="Local browser utility" title="Portal session in. User-controlled artifact out." lede="The pattern distinguishes the portal session, browser action, network destination, and local output without turning privacy copy into a certification claim." compact headingLevel="h2" />
      <PermissionExplainer />
      <CustodyFlow stages={custodyStages} facts={custodyFacts} />
    </section>
    <PatternContractLedger contracts={group.patterns} />
  </main>
</GalleryLayout>
