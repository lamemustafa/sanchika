---
import { productPatternContracts, productPatternGroups } from "@sanchika/patterns";
import { primitiveClassName } from "@sanchika/primitives";
import PatternReferenceHeader from "../../components/patterns/PatternReferenceHeader.astro";
import GalleryLayout from "../../layouts/GalleryLayout.astro";
---

<GalleryLayout
  title="Product pattern contracts | Sanchika"
  description="The canonical Sanchika v0 product-pattern inventory for public pages, Axal, Pack, and Tools."
  canonical="https://sanchika.complyeaze.com/patterns/"
  dataFavicon
>
  <main id="gallery-content" class={`pattern-reference-main ${primitiveClassName("Container", { width: "wide" })}`} data-sanchika-example="synthetic">
    <PatternReferenceHeader
      eyebrow="S7 product pattern contracts"
      title={`${productPatternContracts.length} patterns. Four product modes. One visible trust grammar.`}
      description="This is the package-driven inventory and static reference surface. The canonical gallery redesign remains a separate S8 concern."
    />
    <div class="pattern-reference-inventory">
      {productPatternGroups.map((group) => (
        <section aria-labelledby={`${group.name}-title`}>
          <div>
            <h2 id={`${group.name}-title`}>{group.label}</h2>
            <p>{group.visualCharacter}</p>
            <a href={group.patterns[0].exemplarRoutes[0]}>Open rendered reference</a>
          </div>
          <ol>
            {group.patterns.map((contract) => (
              <li>
                <strong>{contract.name}</strong>
                <span>{contract.purpose}</span>
              </li>
            ))}
          </ol>
        </section>
      ))}
    </div>
  </main>
</GalleryLayout>
