---
import { productPatternGroups } from "@sanchika/patterns";
import PageIntro from "../../components/PageIntro.astro";
import SearchDirectory from "../../components/SearchDirectory.astro";
import { slugForContract } from "../../content/site";
import GalleryLayout from "../../layouts/GalleryLayout.astro";
---
<GalleryLayout title="Patterns | Sanchika" description="Sanchika product patterns across public, workspace, local utility, and browser-local modes.">
  <main id="main-content" class="site-main docs-page" tabindex="-1">
    <PageIntro eyebrow="Patterns" title="Product-shaped contracts with the boundary built in." description="Twenty package patterns turn the shared evidence grammar into four distinct operating modes. Each contract names the product job, source obligations, edge states, and consumer responsibility." meta="20 patterns · four product groups · @sanchika/patterns" />
    {productPatternGroups.map((group) => <section class="doc-section" aria-labelledby={`${group.name}-title`}><h2 id={`${group.name}-title`}>{group.label}</h2><p>{group.visualCharacter}</p><div class="contract-index">{group.patterns.map((contract) => <a href={`/patterns/${slugForContract(contract.name)}/`}><span>{contract.primaryProductMode}</span><strong>{contract.name}</strong><p>{contract.userJob}</p><small>{contract.states.length} states · {contract.evidenceStatus}</small></a>)}</div></section>)}
    <SearchDirectory instanceId="pattern-docs" compact />
  </main>
</GalleryLayout>
