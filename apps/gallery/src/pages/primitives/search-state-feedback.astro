---
import GalleryLayout from "../../layouts/GalleryLayout.astro";
import S5DataPanel from "../../components/S5DataPanel.astro";
import S5ProcessPanel from "../../components/S5ProcessPanel.astro";
import S5SearchPanel from "../../components/S5SearchPanel.astro";
import S5StatePanel from "../../components/S5StatePanel.astro";
import { primitiveClassName, primitiveGroups, textClassName } from "@sanchika/primitives";
import "../../styles/s5-proof.css";

const title = "Search, state, and feedback primitives | Sanchika";
const description = "S5 semantic contracts, progressive enhancement, state evidence, Indian formatting, and responsive data proof.";
const canonical = "https://sanchika.complyeaze.com/primitives/search-state-feedback/";
const contracts = primitiveGroups.searchStateFeedback;
---

<GalleryLayout {title} {description} {canonical} dataFavicon>
  <main id="gallery-content" class={primitiveClassName("Container", { width: "wide" })} data-sanchika-gallery="search-state-feedback" data-sanchika-example="synthetic">
    <header class="s5-proof-masthead"><a class={primitiveClassName("Link", { variant: "quiet" })} href="/">← Sanchika gallery</a><span class={textClassName("eyebrow")}>S5 / search, state, and feedback</span></header>
    <section class={`${primitiveClassName("Section", { space: "lg" })} s5-proof-hero`} aria-labelledby="s5-proof-title"><div class={primitiveClassName("Stack", { gap: "md", align: "start" })}><p class={textClassName("eyebrow")}>Contract-first · static by default · synthetic examples</p><h1 id="s5-proof-title" class={textClassName("display")}>Make the next state legible.</h1><p class={textClassName("lead")}>S5 adds search, loading, absence, recovery, progress, disclosure, copying, navigation, and Indian data display without exporting a framework runtime or beginning S6 motion and S7 product patterns.</p><span class={primitiveClassName("InlineStatus", { tone: "info" })}><span class="sk-inline-status__marker" aria-hidden="true">i</span><span>Consumer behavior remains explicit.</span><span class="sk-inline-status__meta">S5 proof route</span></span></div></section>
    <S5SearchPanel instanceId="s5" />
    <S5StatePanel />
    <S5ProcessPanel />
    <S5DataPanel />
    <section id="s5-contract-ledger" class={primitiveClassName("Section", { space: "lg", boundary: "bordered" })} aria-labelledby="s5-ledger-title">
      <div class={primitiveClassName("Stack", { gap: "md" })}>
        <div><p class={textClassName("eyebrow")}>Authoritative package data</p><h2 id="s5-ledger-title" class={textClassName("heading")}>S5 contract ledger</h2></div>
        {contracts.map((contract) => (
          <details class={primitiveClassName("Disclosure")} data-sk-contract={contract.name}>
            <summary class="sk-disclosure__summary"><strong>{contract.name}</strong> — {contract.role}</summary>
            <div class="sk-disclosure__content">
              <p>{contract.purpose}</p>
              <h3>Required states</h3>
              <ul>{contract.requiredStates.map((state) => <li data-sk-contract-state={state}>{state}</li>)}</ul>
              <h3>State evidence</h3>
              <ul>{contract.stateEvidence.map((evidence) => <li><strong>{evidence.state}</strong>: {evidence.notes}<br /><span>Attributes: {evidence.attributes.join(", ") || "none"}</span><br /><span>Selectors: {evidence.selectors.join(", ")}</span></li>)}</ul>
              <h3>Consumer responsibilities</h3>
              <ul>{contract.consumerResponsibilities.map((responsibility) => <li>{responsibility}</li>)}</ul>
            </div>
          </details>
        ))}
      </div>
    </section>
    <footer class={primitiveClassName("Section", { space: "md", boundary: "bordered" })}><p class={textClassName("caption")}>Static Sanchika evidence. SearchField and CopyButton scripts are zero-dependency gallery references, not package runtime exports.</p></footer>
  </main>
</GalleryLayout>
