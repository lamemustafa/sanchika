{
  "name": "sanchika",
  "version": "0.0.0",
  "private": true,
  "description": "AI-native design system SDK for compliance-grade interfaces.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lamemustafa/sanchika.git"
  },
  "bugs": {
    "url": "https://github.com/lamemustafa/sanchika/issues"
  },
  "homepage": "https://github.com/lamemustafa/sanchika#readme",
  "scripts": {
    "build": "pnpm -r build",
    "build:tokens": "node scripts/build-tokens.mjs",
    "typecheck": "pnpm -r typecheck",
    "typecheck:api": "node scripts/check-package-api-types.mjs",
    "check": "pnpm typecheck",
    "workflow:preflight": "node scripts/check-workflow-preflight.mjs",
    "review:gate": "node scripts/check-pr-review-gate.mjs",
    "review:gate:fixtures": "node scripts/validation/review-gate-fixtures.mjs",
    "review:gate:sync-fixtures": "node scripts/validation/review-gate-sync-fixtures.mjs",
    "trust:brief:fixtures": "node scripts/validation/trust-brief-fixtures.mjs",
    "design:brief:fixtures": "node scripts/validation/design-brief-fixtures.mjs",
    "evidence:loop:fixtures": "node scripts/validation/evidence-loop-fixtures.mjs",
    "github:ruleset": "node scripts/render-github-master-ruleset.mjs",
    "github:labels": "node scripts/sync-github-labels.mjs",
    "github:verify": "node scripts/check-github-repo-state.mjs",
    "hosting:domain:check": "node scripts/check-custom-domain-readiness.mjs",
    "validate": "node scripts/validate-repo.mjs",
    "artifact:check": "node scripts/check-package-artifacts.mjs",
    "consumer:check": "node scripts/check-local-link-consumer.mjs",
    "gallery:build": "pnpm --filter @sanchika/gallery-app build",
    "gallery:check": "node scripts/check-gallery.mjs",
    "gallery:browser": "pnpm --filter @sanchika/gallery-app browser:check",
    "check:tokens": "node scripts/check-token-integrity.mjs",
    "check:gallery": "node scripts/check-gallery-coverage.mjs",
    "check:content": "node scripts/check-content-trust.mjs",
    "pages:smoke": "node scripts/check-pages-smoke.mjs",
    "publish:check": "node scripts/check-publish-ready.mjs",
    "publish:tarball-check": "node scripts/check-packed-tarball-consumer.mjs",
    "smoke:check": "pnpm gallery:check && pnpm check:tokens && pnpm check:gallery && pnpm check:content && pnpm gallery:browser && node scripts/smoke-gallery.mjs",
    "smoke": "pnpm build && pnpm gallery:build && pnpm smoke:check",
    "verify": "pnpm validate && pnpm review:gate:fixtures && pnpm review:gate:sync-fixtures && pnpm typecheck && pnpm build && pnpm trust:brief:fixtures && pnpm design:brief:fixtures && pnpm evidence:loop:fixtures && pnpm typecheck:api && pnpm artifact:check && pnpm consumer:check && pnpm smoke:check",
    "release:tarballs": "pnpm build && node scripts/check-packed-tarball-consumer.mjs --emit-dir dist/release",
    "release:stable-tarballs": "pnpm build && pnpm gallery:browser && node scripts/check-packed-tarball-consumer.mjs --stable-release --emit-dir dist/release"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
